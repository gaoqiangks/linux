set adjust-open "width"
set highlight-transparency 0.0
#current search result
set highlight-active-color "#0000FF"
set highlight-color "#00FF00"
#set highlight-color "#FFFFFF"
map q quit
map t toggle_fullscreen
map <C-i> zoom in
map <C-o> zoom out
#启动时窗口的大小
set window-height 3000
set window-width 3000
#页面显示适合宽度
map w adjust_window width
#鼠标滚动
set scroll-step 100
set adjust-open width
set guioptions ""
map Button1 adjust_window width
