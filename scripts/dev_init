#!/bin/bash
# Debian 多语言开发环境一键初始化脚本（Fish Shell 兼容版）
# 适配 Debian，单包安装失败不中断，支持 C++/Rust/Python/Perl/Lua/Java
# 自动配置 Git、符号链接（目标存在则备份为 .bak），环境变量同时写入 bash & fish

# 颜色输出
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

# 禁止直接 root 运行
if [ "$EUID" -eq 0 ]; then
    echo -e "${RED}错误：请勿直接以root运行，请使用普通用户加sudo权限。${NC}"
    exit 1
fi

# ==============================================
# 1. 系统更新
# ==============================================
echo -e "\n${YELLOW}========== 更新软件源并升级系统 ==========${NC}"
sudo apt update -y
sudo apt upgrade -y

# ==============================================
# 2. 安装 fish shell（你使用的shell）
# ==============================================
echo -e "\n${YELLOW}========== 安装 Fish Shell ==========${NC}"
sudo apt install -y fish || echo -e "${RED}✘ fish 安装失败，继续${NC}"

# 创建fish配置目录（确保存在）
mkdir -p "$HOME/.config/fish"

# ==============================================
# 3. 自定义软件列表（Debian 兼容版，移除Ubuntu专有包）
# ==============================================
echo -e "\n${YELLOW}========== 安装指定软件包（单包失败不中断）==========${NC}"

custom_packages=(
base-files
bash
bsdutils
build-essential
ca-certificates
chromium
containerd.io
coreutils
curl
dash
debianutils
diffutils
docker-buildx-plugin
docker-ce
docker-ce-cli
docker-ce-rootless-extras
docker-compose-plugin
docker-model-plugin
findutils
fonts-freefont-ttf
fonts-ipafont-gothic
fonts-liberation
fonts-noto-color-emoji
fonts-tlwg-loma-otf
fonts-unifont
fonts-wqy-zenhei
gcc
grep
gstreamer1.0-libav
gstreamer1.0-plugins-bad
gstreamer1.0-plugins-base
gstreamer1.0-plugins-good
gzip
hostname
init
libasound2t64
libatk-bridge2.0-0t64
libatk1.0-0t64
libatomic1
libatspi2.0-0t64
libattr1
libavif16
libcairo-gobject2
libcairo2
libcups2t64
libdbus-1-3
libenchant-2-2
libepoxy0
libevent-2.1-7t64
libflite1
libfontconfig1
libfreetype6
libgdk-pixbuf-2.0-0
libgles2
libgstreamer-gl1.0-0
libgstreamer-plugins-bad1.0-0
libgstreamer-plugins-base1.0-0
libgstreamer1.0-0
libgtk-4-1
libharfbuzz-icu0
libharfbuzz0b
libhyphen0
libicu74
libjpeg-turbo8
liblcms2-2
libmanette-0.2-0
libnspr4
libnss3
libopus0
libpango-1.0-0
libpangocairo-1.0-0
libpng16-16t64
libsecret-1-0
libvpx9
libwayland-client0
libwayland-egl1
libwayland-server0
libwebp7
libwebpdemux2
libwoff1
libx11-6
libx11-xcb1
libx264-164
libxcb-shm0
libxcb1
libxcomposite1
libxcursor1
libxdamage1
libxext6
libxfixes3
libxi6
libxkbcommon0
libxml2
libxrandr2
libxrender1
libxslt1.1
login
microsoft-edge-stable
ncurses-base
ncurses-bin
util-linux
xfonts-cyrillic
xfonts-scalable
xvfb
)

# 逐个安装，失败只提示，不退出脚本
for pkg in "${custom_packages[@]}"; do
    echo -e "\n${YELLOW}正在安装：${pkg}${NC}"
    if sudo apt install -y "$pkg"; then
        echo -e "${GREEN}✔ ${pkg} 安装成功${NC}"
    else
        echo -e "${RED}✘ ${pkg} 安装失败，跳过继续${NC}"
    fi
done

# ==============================================
# 4. 通用开发工具
# ==============================================
echo -e "\n${YELLOW}========== 安装通用开发工具 ==========${NC}"
common_dev_packages=(
git
make
cmake
wget
vim
nano
pkg-config
gdb
valgrind
tree
unzip
zip
)

for pkg in "${common_dev_packages[@]}"; do
    echo -e "\n${YELLOW}正在安装：${pkg}${NC}"
    if sudo apt install -y "$pkg"; then
        echo -e "${GREEN}✔ ${pkg} 安装成功${NC}"
    else
        echo -e "${RED}✘ ${pkg} 安装失败，跳过继续${NC}"
    fi
done

# ==============================================
# 5. Git 全局配置（你的信息）
# ==============================================
echo -e "\n${YELLOW}========== 配置 Git 用户信息 ==========${NC}"
git config --global user.name "gaoqiang"
git config --global user.email "gaoqiangks@qq.com"
git config --global core.editor "vim"
echo -e "${GREEN}Git 配置完成：${NC}"
git config --global --list | grep -E "user.name|user.email|core.editor"

# ==============================================
# 6. 批量创建符号链接（核心改动：目标存在则备份为 .bak）
# ==============================================
echo -e "\n${YELLOW}========== 创建配置符号链接（目标存在则备份为 .bak）==========${NC}"

link_list=(
"$HOME/linux/nvim"       "$HOME/.config/nvim"
"$HOME/linux/nvim"       "$HOME/.config/nvimpager"
"$HOME/linux/fish"       "$HOME/.config/fish"
"$HOME/linux/atuin"      "$HOME/.config/atuin"
)

for ((i=0; i<${#link_list[@]}; i+=2)); do
    src="${link_list[$i]}"
    dest="${link_list[$i+1]}"
    dest_bak="${dest}.bak"

    # 1. 检查源路径是否存在
    if [ ! -e "$src" ]; then
        echo -e "${YELLOW}源不存在，跳过：$src${NC}"
        continue
    fi

    # 2. 处理目标路径已存在的情况：无论类型，均备份为 .bak
    if [ -e "$dest" ] || [ -L "$dest" ]; then
        # 若备份文件已存在，直接覆盖（避免报错）
        if [ -e "$dest_bak" ] || [ -L "$dest_bak" ]; then
            rm -rf "$dest_bak"
            echo -e "${YELLOW}已删除原有备份文件：$dest_bak${NC}"
        fi
        # 重命名目标为 .bak 备份
        mv -v "$dest" "$dest_bak"
        echo -e "${YELLOW}已备份原有目标文件/目录/链接：$dest -> $dest_bak${NC}"
    fi

    # 3. 自动创建目标路径的父目录（避免创建链接失败）
    dest_dir=$(dirname "$dest")
    [ ! -d "$dest_dir" ] && mkdir -p "$dest_dir" && echo -e "${GREEN}已创建父目录：$dest_dir${NC}"

    # 4. 创建新的符号链接并验证
    if ln -sv "$src" "$dest"; then
        echo -e "${GREEN}✔ 符号链接创建成功：$src -> $dest${NC}"
    else
        echo -e "${RED}✘ 符号链接创建失败：$src -> $dest${NC}"
    fi
done

echo -e "${GREEN}符号链接批量处理流程执行完成！${NC}"

# ==============================================
# 7. C++ 开发环境
# ==============================================
echo -e "\n${YELLOW}========== 安装 C++ 开发环境 ==========${NC}"
cpp_packages=(
g++
clang++
clang-format
clang-tidy
libboost-all-dev
libopencv-dev
libeigen3-dev
libssl-dev
libcurl4-openssl-dev
qtbase5-dev
qtcreator
)

for pkg in "${cpp_packages[@]}"; do
    echo -e "\n${YELLOW}正在安装：${pkg}${NC}"
    sudo apt install -y "$pkg" || echo -e "${RED}✘ ${pkg} 安装失败，继续${NC}"
done

# ==============================================
# 8. Rust 官方安装（rustup）
# ==============================================
echo -e "\n${YELLOW}========== 安装 Rust 工具链 ==========${NC}"
if ! command -v rustup &> /dev/null; then
    curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y
    # 临时加载cargo环境，保证脚本后续可用
    source "$HOME/.cargo/env"
    rustup component add rustfmt clippy rust-analyzer 2>/dev/null
else
    echo -e "${GREEN}rustup 已存在，跳过${NC}"
fi

# ==============================================
# 9. Python 开发环境 + 双Shell兼容配置
# ==============================================
echo -e "\n${YELLOW}========== 安装 Python 开发环境 ==========${NC}"
python_packages=(
python3
python3-dev
python3-pip
python3-venv
python3-tk
ipython3
python3-pytest
python3-numpy
python3-pandas
python3-matplotlib
python3-requests
)

for pkg in "${python_packages[@]}"; do
    echo -e "\n${YELLOW}正在安装：${pkg}${NC}"
    sudo apt install -y "$pkg" || echo -e "${RED}✘ ${pkg} 安装失败，继续${NC}"
done

# 升级 pip
python3 -m pip install --upgrade pip -q || true

# --- 配置 python/pip 别名：同时兼容 bash 和 fish ---
echo -e "\n${YELLOW}========== 配置 Python 别名（Bash + Fish）==========${NC}"

# 写入 bash
bashrc="$HOME/.bashrc"
if ! grep -q "alias python=python3" "$bashrc"; then
    echo "alias python=python3" >> "$bashrc"
    echo "alias pip=pip3" >> "$bashrc"
    echo -e "${GREEN}已添加 Python 别名到 .bashrc${NC}"
fi

# 写入 fish
fish_conf="$HOME/.config/fish/config.fish"
if [ -f "$fish_conf" ] || [ -d "$HOME/.config/fish" ]; then
    if ! grep -q "alias python python3" "$fish_conf"; then
        echo "alias python python3" >> "$fish_conf"
        echo "alias pip pip3" >> "$fish_conf"
        echo -e "${GREEN}已添加 Python 别名到 fish config.fish${NC}"
    fi
fi

# ==============================================
# 10. Perl 开发环境
# ==============================================
echo -e "\n${YELLOW}========== 安装 Perl 开发环境 ==========${NC}"
perl_packages=(
perl
perl-dev
cpanminus
libperl5-perl
libjson-perl
libwww-perl
libdbi-perl
libxml-perl
perl-doc
)

for pkg in "${perl_packages[@]}"; do
    echo -e "\n${YELLOW}正在安装：${pkg}${NC}"
    sudo apt install -y "$pkg" || echo -e "${RED}✘ ${pkg} 安装失败，继续${NC}"
done

# 安装常用模块，失败不影响
cpanm -q --notest Data::Dumper JSON::XS LWP::Simple 2>/dev/null || true

# ==============================================
# 11. Lua 开发环境
# ==============================================
echo -e "\n${YELLOW}========== 安装 Lua 开发环境 ==========${NC}"
lua_packages=(
lua5.4
luac5.4
luarocks
liblua5.4-dev
lua5.4-json
lua5.4-socket
lua5.4-posix
)

for pkg in "${lua_packages[@]}"; do
    echo -e "\n${YELLOW}正在安装：${pkg}${NC}"
    sudo apt install -y "$pkg" || echo -e "${RED}✘ ${pkg} 安装失败，继续${NC}"
done

# 配置 luarocks
if command -v luarocks &>/dev/null; then
    luarocks config local_by_default true
    luarocks install luafilesystem 2>/dev/null || true
    luarocks install lua-cjson 2>/dev/null || true
fi

# ==============================================
# 12. Java OpenJDK 17 + 双Shell环境变量配置
# ==============================================
echo -e "\n${YELLOW}========== 安装 Java 开发环境 ==========${NC}"
java_packages=(
openjdk-17-jdk
openjdk-17-jre
maven
gradle
ant
javadoc
)

for pkg in "${java_packages[@]}"; do
    echo -e "\n${YELLOW}正在安装：${pkg}${NC}"
    sudo apt install -y "$pkg" || echo -e "${RED}✘ ${pkg} 安装失败，继续${NC}"
done

# 配置 JAVA_HOME，同时写入 bash 和 fish
java_home_path="/usr/lib/jvm/java-17-openjdk-amd64"
if [ -d "$java_home_path" ]; then
    echo -e "\n${YELLOW}========== 配置 JAVA_HOME（Bash + Fish）==========${NC}"
    
    # 写入 bash
    if ! grep -q "JAVA_HOME" "$bashrc"; then
        echo "export JAVA_HOME=$java_home_path" >> "$bashrc"
        echo "export PATH=\$PATH:\$JAVA_HOME/bin" >> "$bashrc"
    fi
    
    # 写入 fish
    if ! grep -q "JAVA_HOME" "$fish_conf"; then
        echo "set -x JAVA_HOME $java_home_path" >> "$fish_conf"
        echo "set -x PATH \$PATH \$JAVA_HOME/bin" >> "$fish_conf"
    fi
    
    echo -e "${GREEN}JAVA_HOME 已同时配置到 Bash & Fish${NC}"
fi

# ==============================================
# 13. 加载 Fish 下的 Cargo 环境
# ==============================================
echo -e "\n${YELLOW}========== 配置 Rust Cargo 环境到 Fish ==========${NC}"
cargo_env_line="source $HOME/.cargo/env.fish"
if [ -f "$HOME/.cargo/env.fish" ] && [ -f "$fish_conf" ]; then
    if ! grep -q "$cargo_env_line" "$fish_conf"; then
        echo "$cargo_env_line" >> "$fish_conf"
        echo -e "${GREEN}已将 Cargo 环境加入 Fish 配置${NC}"
    fi
fi

# ==============================================
# 14. 版本信息汇总
# ==============================================
echo -e "\n${GREEN}=========================================================${NC}"
echo -e "${GREEN}环境初始化流程执行完成（单包失败不会中断）${NC}"
echo -e "${YELLOW}Bash：执行 source ~/.bashrc 生效${NC}"
echo -e "${YELLOW}Fish：执行 source ~/.config/fish/config.fish 生效${NC}"
echo -e "${YELLOW}符号链接备份说明：原有目标已备份为 .bak 后缀，可在对应目录下找到${NC}"
echo -e "\n${GREEN}关键工具版本检查：${NC}"

echo -e "\n--- 通用 ---"
git --version 2>/dev/null | head -1 || echo "git 未安装"
cmake --version 2>/dev/null | head -1 || echo "cmake 未安装"
docker --version 2>/dev/null | head -1 || echo "docker 未安装"
fish --version 2>/dev/null | head -1 || echo "fish 未安装"

echo -e "\n--- C++ ---"
g++ --version 2>/dev/null | head -1 || echo "g++ 未安装"
clang++ --version 2>/dev/null | head -1 || echo "clang++ 未安装"

echo -e "\n--- Rust ---"
rustc --version 2>/dev/null | head -1 || echo "rust 未安装"
cargo --version 2>/dev/null | head -1 || echo "cargo 未安装"

echo -e "\n--- Python ---"
python3 --version 2>/dev/null || echo "python3 未安装"
pip3 --version 2>/dev/null || echo "pip3 未安装"

echo -e "\n--- Perl ---"
perl --version 2>/dev/null | head -1 || echo "perl 未安装"

echo -e "\n--- Lua ---"
lua5.4 -v 2>/dev/null || echo "lua5.4 未安装"

echo -e "\n--- Java ---"
java --version 2>/dev/null | head -1 || echo "java 未安装"
javac --version 2>/dev/null | head -1 || echo "java 未安装"
mvn --version 2>/dev/null | head -1 || echo "maven 未安装"

echo -e "\n${GREEN}=========================================================${NC}"
