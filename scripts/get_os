#!/usr/bin/env python3
import subprocess
import os

def determine_os_environment():
    # 获取系统名称（对应fish的 set -l os_name (uname)）
    try:
        # 调用uname命令，捕获输出并去除首尾空白字符
        os_name = subprocess.check_output(
            ['uname'],
            stderr=subprocess.DEVNULL,  # 等价于fish的2>/dev/null，屏蔽错误输出
            text=True                   # 输出为字符串格式（而非字节流）
        ).strip()
    except subprocess.CalledProcessError:
        # 若uname命令执行失败（极少数系统不支持），直接判定为unknown
        print("unknown")
        return 1
    except FileNotFoundError:
        print("unknown")
        return 1

    # 对应fish的switch $os_name分支判断
    if os_name == "Darwin":
        # macOS 环境，对应fish的case "Darwin"
        print("macos")
        return 0
    elif os_name == "Linux":
        # Linux 环境，需要区分纯Linux和WSL，对应fish的case "Linux"
        proc_version_path = "/proc/version"
        is_wsl = False

        # 先检查/proc/version文件是否存在（避免文件不存在导致报错）
        if os.path.exists(proc_version_path):
            try:
                # 对应fish的 cat /proc/version | grep -qEi 'microsoft|wsl'
                # 调用grep命令，-q静默模式（不输出内容，仅返回退出状态）
                subprocess.check_call(
                    ['grep', '-qEi', 'microsoft|wsl', proc_version_path],
                    stdout=subprocess.DEVNULL,  # 屏蔽标准输出
                    stderr=subprocess.DEVNULL   # 屏蔽错误输出
                )
                is_wsl = True  # 若grep找到匹配内容，退出状态为0，判定为WSL
            except subprocess.CalledProcessError:
                # grep未找到匹配内容，退出状态非0，判定为纯Linux
                is_wsl = False

        if is_wsl:
            print("wsl")
        else:
            print("linux")
        return 0
    else:
        # 其他未知环境，对应fish的case "*"
        print("unknown")
        return 1

# 可选：直接调用函数测试（如需要脚本独立运行，取消注释即可）
if __name__ == "__main__":
    determine_os_environment()
