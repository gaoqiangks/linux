#!/bin/bash

# 定义帮助信息函数
print_help() {
    echo "=============================================="
    echo "  增强版文本搜索脚本"
    echo "=============================================="
    echo "使用方法: $0 [选项] [搜索关键词]"
    echo ""
    echo "选项说明:"
    echo "  -h, --help    打印本帮助信息并退出"
    echo "  -c            仅打印匹配结果的数量，不展示详细内容"
    echo ""
    echo "功能说明:"
    echo "  1. 在 $HOME/search.txt 文件中忽略大小写搜索指定关键词"
    echo "  2. 无 -c 参数时，显示匹配行前后各2行上下文，通过 nvimpager 以Vim风格展示"
    echo "  3. 带 -c 参数时，仅输出匹配结果的总数量"
    echo ""
    echo "示例:"
    echo "  $0 hello    # 搜索关键词 'hello' 并展示详细内容"
    echo "  $0 -c hello # 仅统计关键词 'hello' 的匹配数量"
    echo "  $0 --help   # 查看帮助信息"
    echo "=============================================="
}

# 定义全局变量标记是否仅统计数量
count_only=0
search_keyword=""

# 步骤1: 解析命令行参数
while [ $# -gt 0 ]; do
    case "$1" in
        -h|--help)
            print_help
            exit 0
            ;;
        -c)
            count_only=1  # 标记为仅统计数量模式
            shift  # 跳过当前参数，处理下一个
            ;;
        *)
            # 捕获搜索关键词（非选项参数）
            if [ -z "$search_keyword" ]; then
                search_keyword="$1"
            else
                echo "错误: 不支持多个搜索关键词！"
                echo "提示: 执行 $0 -h 查看帮助信息"
                exit 1
            fi
            shift
            ;;
    esac
done

# 步骤2: 检查是否提供了有效的搜索关键词
if [ -z "$search_keyword" ]; then
    echo "错误: 未提供搜索关键词！"
    echo "提示: 执行 $0 -h 查看帮助信息"
    exit 1
fi

# 步骤3: 检查依赖命令是否安装（-c 模式仅依赖 rg，仍统一检查保证兼容性）
check_command() {
    if ! command -v "$1" &> /dev/null; then
        echo "错误: 命令 '$1' 未安装，请先安装后再运行脚本！"
        exit 1
    fi
}

# 验证 rg (ripgrep) （必须安装）
check_command "rg"
# 非 -c 模式下，验证 nvimpager
if [ $count_only -eq 0 ]; then
    check_command "nvimpager"
fi

# 步骤4: 定义目标文件路径并检查文件是否存在
target_file="$HOME/search.txt"
if [ ! -f "$target_file" ]; then
    echo "错误: 文件 $target_file 不存在！"
    echo "提示: 请先在用户家目录创建 search.txt 文件并写入内容"
    exit 1
fi

# 步骤5: 分模式执行逻辑
if [ $count_only -eq 1 ]; then
    # -c 模式：仅统计匹配数量
    echo "正在统计 $target_file 中关键词 '$search_keyword' 的匹配数量（忽略大小写）..."
    match_count=$(rg "$search_keyword" "$target_file" --ignore-case --count)
    echo "----------------------------------------------"
    echo "匹配结果总数: $match_count 行"
else
    # 正常模式：处理正则格式，展示详细内容
    vim_pattern=$(echo "$search_keyword" | sed 's/{/\\{/g')
    echo "正在在 $target_file 中搜索关键词: '$search_keyword'（忽略大小写）..."
    echo "----------------------------------------------"
    rg "$search_keyword" "$target_file" -C 2 --ignore-case | \
    nvimpager +"set nu" \
              +"hi Search guifg=#c0caf5 guibg=#3d59a1" \
              +"hi IncSearch guifg=#15161e guibg=#ff0000" \
              +"/$vim_pattern\c"
fi
