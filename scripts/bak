#!/bin/bash

# 定义帮助信息（可选，提升易用性）
print_help() {
    echo "脚本功能：将指定文件备份为 原文件名.bak 格式"
    echo "使用方法：$0 [待备份文件路径]"
    echo "示例：$0 /home/user/test.txt （备份后生成 /home/user/test.txt.bak）"
}

# 步骤1：检查参数是否合法
# 1.1 检查是否传入参数（支持 -h/--help 查看帮助）
if [ "$1" = "-h" ] || [ "$1" = "--help" ]; then
    print_help
    exit 0
fi

# 1.2 检查是否未传入任何参数
if [ -z "$1" ]; then
    echo "错误：未提供待备份的文件！"
    echo "提示：执行 $0 -h 查看使用帮助"
    exit 1
fi

# 步骤2：定义变量，获取输入文件和备份文件路径
source_file="$1"
backup_file="${source_file}.bak"

# 步骤3：核心检查（避免无效操作）
# 3.1 检查原文件是否存在且为普通文件
if [ ! -f "$source_file" ]; then
    echo "错误：文件 '$source_file' 不存在，或不是普通文件！"
    exit 1
fi

# 3.2 检查备份文件是否已存在（避免覆盖已有备份）
if [ -f "$backup_file" ]; then
    echo "警告：备份文件 '$backup_file' 已存在！"
    read -p "是否覆盖已有备份？（y/n，默认n）：" choice
    # 处理用户输入，默认选择 n（不覆盖）
    case "$choice" in
        [Yy]|[Yy][Ee][Ss])
            echo "即将覆盖已有备份文件..."
            ;;
        *)
            echo "备份操作已取消！"
            exit 0
            ;;
    esac
fi

# 步骤4：执行备份（重命名操作）
if mv "$source_file" "$backup_file"; then
    echo "备份成功！"
    echo "原文件：$source_file"
    echo "备份文件：$backup_file"
else
    echo "错误：备份失败！"
    exit 1
fi
